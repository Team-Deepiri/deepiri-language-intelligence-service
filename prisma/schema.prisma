generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Obligation {
  id                     String                 @id @default(uuid()) @db.Uuid
  intelligenceDocumentId String?                @map("intelligence_document_id") @db.Uuid
  description            String
  obligationType         ObligationType         @map("obligation_type")
  party                  String                 @db.VarChar(50)
  deadline               DateTime?              @db.Timestamp(6)
  startDate              DateTime?              @map("start_date") @db.Timestamp(6)
  endDate                DateTime?              @map("end_date") @db.Timestamp(6)
  frequency              String?                @db.VarChar(50)
  amount                 Float?
  currency               String?                @default("USD") @db.VarChar(10)
  sourceSnippet          String?                @map("source_clause")
  confidence             Float?
  status                 ObligationStatus       @default(PENDING)
  completedAt            DateTime?              @map("completed_at") @db.Timestamp(6)
  owner                  String?                @db.VarChar(255)
  ownerEmail             String?                @map("owner_email") @db.VarChar(255)
  tags                   String[]               @default([])
  notes                  String?
  metadata               Json?                  @default("{}")
  createdAt              DateTime               @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt              DateTime               @updatedAt @map("updated_at") @db.Timestamp(6)
  sourceDependencies     ObligationDependency[] @relation("SourceObligations")
  targetDependencies     ObligationDependency[] @relation("TargetObligations")
  intelligenceDocument   IntelligenceDocument?  @relation(fields: [intelligenceDocumentId], references: [id], onDelete: Cascade)

  @@index([intelligenceDocumentId])
  @@index([status])
  @@index([deadline])
  @@index([obligationType])
  @@map("obligations")
}

model ObligationDependency {
  id                 String         @id @default(uuid()) @db.Uuid
  sourceObligationId String         @map("source_obligation_id") @db.Uuid
  targetObligationId String         @map("target_obligation_id") @db.Uuid
  dependencyType     DependencyType @map("dependency_type")
  description        String?
  confidence         Float?
  sourceSnippet      String?        @map("source_clause")
  targetSnippet      String?        @map("target_clause")
  triggerCondition   String?        @map("trigger_condition")
  discoveredAt       DateTime       @default(now()) @map("discovered_at") @db.Timestamp(6)
  discoveredBy       String?        @map("discovered_by") @db.VarChar(50)
  verified           Boolean        @default(false)
  verifiedAt         DateTime?      @map("verified_at") @db.Timestamp(6)
  verifiedBy         String?        @map("verified_by") @db.Uuid
  metadata           Json?          @default("{}")
  createdAt          DateTime       @default(now()) @map("created_at") @db.Timestamp(6)
  sourceObligation   Obligation     @relation("SourceObligations", fields: [sourceObligationId], references: [id], onDelete: Cascade)
  targetObligation   Obligation     @relation("TargetObligations", fields: [targetObligationId], references: [id], onDelete: Cascade)

  @@unique([sourceObligationId, targetObligationId])
  @@index([sourceObligationId])
  @@index([targetObligationId])
  @@index([dependencyType])
  @@index([verified])
  @@map("obligation_dependencies")
}

/// Processed uploads: open-vocabulary `documentKind` and `intelligenceProfile` (maps to external pipeline URLs).
model IntelligenceDocument {
  id                   String                    @id @default(uuid()) @db.Uuid
  documentKey          String                    @unique @map("document_key") @db.VarChar(200)
  documentKind         String                    @map("document_kind") @db.VarChar(120)
  intelligenceProfile  String                    @map("intelligence_profile") @db.VarChar(120)
  profileHints         Json?                     @map("profile_hints")
  documentUrl          String                    @map("document_url")
  documentStorageKey   String?                   @map("document_storage_key") @db.VarChar(255)
  rawText              String?                   @map("raw_text")
  documentType         String                    @default("PDF") @map("document_type") @db.VarChar(50)
  fileSize             Int?                      @map("file_size")
  status               IntelligenceDocumentStatus @default(PENDING)
  processingStatus     String?                   @map("processing_status") @db.VarChar(50)
  processingError      String?                   @map("processing_error")
  processedAt          DateTime?                 @map("processed_at") @db.Timestamp(6)
  processingTimeMs     Int?                      @map("processing_time_ms")
  abstractedTerms      Json?                     @map("abstracted_terms")
  financialTerms       Json?                     @map("financial_terms")
  keyDates             Json?                     @map("key_dates")
  extractedSupplement  Json?                     @map("extracted_supplement")
  structuredSegments   Json?                     @map("structured_segments")
  terminationDetails   Json?                     @map("termination_details")
  renewalDetails       Json?                     @map("renewal_details")
  extractionConfidence Float?                    @map("extraction_confidence")
  validationScore      Float?                    @map("validation_score")
  userId               String?                   @map("user_id") @db.Uuid
  organizationId       String?                   @map("organization_id") @db.Uuid
  tags                 String[]                  @default([])
  notes                String?
  metadata             Json?                     @default("{}")
  createdAt            DateTime                  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt            DateTime                  @updatedAt @map("updated_at") @db.Timestamp(6)
  createdBy            String?                   @map("created_by") @db.Uuid
  updatedBy            String?                   @map("updated_by") @db.Uuid
  versions             IntelligenceDocumentVersion[]
  obligations          Obligation[]

  @@index([documentKey])
  @@index([documentKind])
  @@index([intelligenceProfile])
  @@index([status])
  @@index([userId])
  @@index([organizationId])
  @@map("unified_documents")
}

model IntelligenceDocumentVersion {
  id                     String               @id @default(uuid()) @db.Uuid
  intelligenceDocumentId String               @map("intelligence_document_id") @db.Uuid
  versionNumber          Int                  @map("version_number")
  documentUrl            String               @map("document_url")
  rawText                String               @map("raw_text")
  abstractedTerms        Json                 @map("abstracted_terms")
  changes                Json?
  changeSummary          String?              @map("change_summary")
  changeType             String?              @map("change_type") @db.VarChar(50)
  significantChanges     Boolean              @default(false) @map("significant_changes")
  processedAt            DateTime             @default(now()) @map("processed_at") @db.Timestamp(6)
  processingTimeMs       Int?                 @map("processing_time_ms")
  metadata               Json?                @default("{}")
  createdAt              DateTime             @default(now()) @map("created_at") @db.Timestamp(6)
  createdBy              String?              @map("created_by") @db.Uuid
  intelligenceDocument   IntelligenceDocument @relation(fields: [intelligenceDocumentId], references: [id], onDelete: Cascade)

  @@unique([intelligenceDocumentId, versionNumber])
  @@index([intelligenceDocumentId])
  @@index([versionNumber])
  @@map("unified_document_versions")
}

model Document {
  id           String          @id @default(uuid()) @db.Uuid
  userId       String          @db.Uuid
  title        String?         @db.VarChar(500)
  sourceUrl    String?         @map("source_url")
  sourceType   String?         @map("source_type") @db.VarChar(50)
  content      String?         @map("content")
  metadata     Json?           @map("metadata")
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime        @updatedAt @map("updated_at") @db.Timestamp(6)
  analysisJobs AnalysisJob[]   @relation("DocumentAnalysisJobs")
  chunks       DocumentChunk[] @relation("DocumentChunks")

  @@index([userId, createdAt])
  @@index([userId])
  @@map("documents")
}

model DocumentChunk {
  id           String        @id @default(uuid()) @db.Uuid
  documentId   String        @db.Uuid
  userId       String        @db.Uuid
  chunkOrder   Int           @map("chunk_order")
  text         String
  tokenCount   Int?          @map("token_count")
  startOffset  Int?          @map("start_offset")
  endOffset    Int?          @map("end_offset")
  metadata     Json?         @map("metadata")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamp(6)
  analysisJobs AnalysisJob[]
  document     Document      @relation("DocumentChunks", fields: [documentId], references: [id], onDelete: Cascade)
  embeddings   Embedding[]   @relation("ChunkEmbeddings")

  @@unique([documentId, chunkOrder])
  @@index([documentId])
  @@index([userId])
  @@map("document_chunks")
}

model AnalysisJob {
  id             String          @id @default(uuid()) @db.Uuid
  userId         String          @db.Uuid
  documentId     String?         @db.Uuid
  chunkId        String?         @db.Uuid
  type           AnalysisType    @default(OTHER)
  status         JobStatus       @default(PENDING)
  input          Json?           @map("input")
  promptSnapshot Json?           @map("prompt_snapshot")
  startedAt      DateTime?       @map("started_at") @db.Timestamp(6)
  completedAt    DateTime?       @map("completed_at") @db.Timestamp(6)
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamp(6)
  chunk          DocumentChunk?  @relation(fields: [chunkId], references: [id])
  document       Document?       @relation("DocumentAnalysisJobs", fields: [documentId], references: [id], onDelete: Cascade)
  result         AnalysisResult?

  @@index([userId, createdAt])
  @@index([status])
  @@index([documentId])
  @@index([chunkId])
  @@map("analysis_jobs")
}

model AnalysisResult {
  id         String      @id @default(uuid()) @db.Uuid
  jobId      String      @unique @map("job_id") @db.Uuid
  userId     String      @db.Uuid
  result     Json?       @map("result")
  textOutput String?     @map("text_output")
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt  DateTime    @updatedAt @map("updated_at") @db.Timestamp(6)
  job        AnalysisJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("analysis_results")
}

model Embedding {
  id              String                 @id @default(uuid()) @db.Uuid
  chunkId         String                 @db.Uuid
  userId          String                 @db.Uuid
  model           String                 @db.VarChar(200)
  dims            Int
  vector          Unsupported("vector")? @map("vector")
  vector_fallback Json?                  @map("vector_fallback")
  metadata        Json?                  @map("metadata")
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime               @updatedAt @map("updated_at") @db.Timestamp(6)
  chunk           DocumentChunk          @relation("ChunkEmbeddings", fields: [chunkId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([chunkId])
  @@map("embeddings")
}

model PromptTemplate {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  name      String   @db.VarChar(200)
  version   Int
  template  String
  metadata  Json?    @map("metadata")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  @@unique([userId, name, version])
  @@index([userId])
  @@map("prompt_templates")
}

enum IntelligenceDocumentStatus {
  PENDING
  PROCESSING
  COMPLETED
  ERROR
  ARCHIVED
}

enum ObligationType {
  PAYMENT
  MAINTENANCE
  NOTIFICATION
  COMPLIANCE
  RENEWAL
  TERMINATION
  INSURANCE
  TAX
  UTILITY
  REPAIR
  INSPECTION
  DELIVERY
  PERFORMANCE
  CONFIDENTIALITY
  OTHER
}

enum ObligationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
  CANCELLED
}

enum DependencyType {
  TRIGGERS
  BLOCKS
  MODIFIES
  REQUIRES
  PRECEDES
  CONFLICTS
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum AnalysisType {
  EMBEDDING
  EXTRACTION
  SUMMARIZATION
  CLASSIFICATION
  RAG
  OTHER
}

model ChatSession {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  contextId   String?  @map("context_id") @db.VarChar(255)
  contextType String?  @map("context_type") @db.VarChar(50)
  title       String   @default("New Conversation") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  messages    Message[]

  @@index([userId])
  @@index([contextId])
  @@map("chat_sessions")
}

model Message {
  id            String      @id @default(uuid()) @db.Uuid
  chatSessionId String      @map("chat_session_id") @db.Uuid
  role          String      @db.VarChar(50)
  content       String
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamp(6)
  
  chatSession   ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId])
  @@map("messages")
}
